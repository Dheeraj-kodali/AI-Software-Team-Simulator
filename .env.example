# Copy this file to .env and configure the keys
# Do NOT commit your actual .env file with real keys to git

GROQ_API_KEY_1=your_first_groq_api_key_here
GROQ_API_KEY_2=your_second_groq_api_key_here
GROQ_API_KEY_3=your_third_groq_api_key_here

# Rotation settings
ROTATION_STRATEGY=each_call  # Option: 'each_call' or 'token_limit'
TOKEN_LIMIT_PER_KEY=5000     # Used only if strategy is 'token_limit'
